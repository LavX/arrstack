networks:
  arrstack:
    driver: bridge

services:
{{#each services}}
  {{id}}:
    container_name: {{id}}
    image: {{image}}:{{tag}}
{{#if build}}
    build:
      context: {{build.context}}
      dockerfile: {{build.dockerfile}}
{{/if}}
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"
{{#if vpnNetwork}}
    network_mode: "service:gluetun"
{{else}}
    networks:
      - arrstack
{{/if}}
{{#if ports}}
    ports:
{{#each ports}}
      - "{{binding}}"
{{/each}}
{{/if}}
    environment:
      - PUID={{../puid}}
      - PGID={{../pgid}}
      - TZ={{../timezone}}
{{#if apiKeyEnv}}
      - {{apiKeyEnv}}={{apiKey}}
{{/if}}
{{#each extraEnv}}
      - {{key}}={{value}}
{{/each}}
    volumes:
      - {{../installDir}}/config/{{id}}:{{configPath}}
{{#each dataMounts}}
      - {{src}}:{{dst}}
{{/each}}
{{#if devices}}
    devices:
{{#each devices}}
      - {{this}}
{{/each}}
{{/if}}
{{#if capAdd}}
    cap_add:
{{#each capAdd}}
      - {{this}}
{{/each}}
{{/if}}
{{#if groupAdd}}
    group_add:
{{#each groupAdd}}
      - "{{this}}"
{{/each}}
{{/if}}
{{#if dependsOn}}
    depends_on:
{{#each dependsOn}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
