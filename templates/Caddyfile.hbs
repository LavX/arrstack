{{#if localDnsEnabled}}
{{#each services}}
# Hostname vhost on HTTP. Resolved via dnsmasq if installed, otherwise add
# "HOST_IP {{id}}.{{../localDnsTld}}" to the client's /etc/hosts.
#
# Emitted in every remote_access mode: when duckdns/cloudflare is also on,
# this HTTP vhost is the LAN-only escape hatch that still works when Let's
# Encrypt hasn't issued the wildcard cert yet (or when the box can't reach
# LE at all). Without it, hitting http://{svc}.{tld} would fall through to
# Caddy's default welcome page instead of the service.
http://{{id}}.{{../localDnsTld}} {
	reverse_proxy {{id}}:{{port}}
}
{{/each}}
{{/if}}
{{#if (eq mode "cloudflare")}}
# One wildcard cert for *.{{domain}} instead of per-service certs. Each POST
# to Let's Encrypt DNS-01 costs a challenge round-trip, and LE rate-limits
# at 50 certificates per registered domain per week — issuing N certs for
# N services burns through that budget fast and slows the install. A single
# *.{{domain}} cert covers every subdomain we host and renews once.
*.{{domain}} {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
{{#each services}}
	@{{id}} host {{id}}.{{../domain}}
	handle @{{id}} {
		reverse_proxy {{id}}:{{port}}
	}
{{/each}}
	# Unknown subdomain: don't leak a random service, just 404.
	handle {
		respond 404
	}
}
{{/if}}
{{#if (eq mode "duckdns")}}
# One wildcard cert for *.{{domain}} instead of per-service certs. DuckDNS
# auto-resolves any subdomain of a registered name to the same A record,
# so *.{{domain}} covers every {id}.{{domain}} we route here. Each
# per-service cert would otherwise cost its own DNS-01 round-trip and
# chip away at Let's Encrypt's 50-certs-per-registered-domain weekly cap.
*.{{domain}} {
	tls {
		dns duckdns {env.DUCKDNS_TOKEN}
	}
{{#each services}}
	@{{id}} host {{id}}.{{../domain}}
	handle @{{id}} {
		reverse_proxy {{id}}:{{port}}
	}
{{/each}}
	# Unknown subdomain: don't leak a random service, just 404.
	handle {
		respond 404
	}
}
{{/if}}
