{{#each services}}
{{#if (eq ../mode "none")}}
{{#if ../localDnsEnabled}}
# Hostname vhost on HTTP. Resolved via dnsmasq if installed, otherwise add
# "HOST_IP {{id}}.{{../localDnsTld}}" to the client's /etc/hosts.
http://{{id}}.{{../localDnsTld}} {
	reverse_proxy {{id}}:{{port}}
}
{{/if}}
{{/if}}
{{#if (eq ../mode "cloudflare")}}
{{id}}.{{../domain}} {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	reverse_proxy {{id}}:{{port}}
}
{{/if}}
{{#if (eq ../mode "duckdns")}}
{{id}}.{{../domain}} {
	tls {
		dns duckdns {env.DUCKDNS_TOKEN}
	}
	reverse_proxy {{id}}:{{port}}
}
{{/if}}
{{/each}}
