{
  "name": "arrstack-installer",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "arrstack": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --minify --target=bun-linux-x64 src/cli.ts --outfile dist/arrstack-linux-x64",
    "build:arm64": "bun build --compile --minify --target=bun-linux-arm64 src/cli.ts --outfile dist/arrstack-linux-arm64",
    "test": "bun test",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx}'"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.12",
    "ink-testing-library": "^4.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "handlebars": "^4.7.9",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5",
    "undici": "^8.1.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
